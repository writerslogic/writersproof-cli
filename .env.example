# CPOE Environment Variables
# Copy to .env and customize (never commit .env!)

# Database paths (defaults shown)
CPOE_EVENT_STORE=/home/user/.writerslogic/events.db
CPOE_MMR_PATH=/home/user/.writerslogic/mmr.bin
CPOE_CONFIG=/home/user/.writerslogic/config.toml

# Signing key path
CPOE_SIGNING_KEY=/home/user/.ssh/cpoe_signing_key

# TPM configuration (optional)
CPOE_TPM_DEVICE=/dev/tpmrm0
CPOE_TPM_SIMULATOR=false
TPM2TOOLS_TCTI=device:/dev/tpmrm0

# External timestamping (optional)
CPOE_TSA_URL=https://freetsa.org/tsr
CPOE_OTS_CALENDAR=https://a.pool.opentimestamps.org

# Logging
CPOE_LOG_LEVEL=info
CPOE_AUDIT_LOG=/var/log/cpoe/audit.log

# Development/testing
CPOE_DEBUG=false
CPOE_TEST_MODE=false
