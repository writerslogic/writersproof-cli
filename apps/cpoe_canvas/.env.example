# Canvas LMS Configuration
CANVAS_PLATFORM_URL=https://your-school.instructure.com
CANVAS_CLIENT_ID=your_developer_key_client_id

# Canvas API access token (for content monitoring)
# CANVAS_ACCESS_TOKEN=your_canvas_access_token

# Webhook Security (optional)
# CANVAS_WEBHOOK_SECRET=your_webhook_secret

# Session
SESSION_SECRET=generate_a_long_random_string_here

# WritersProof API
WRITERSPROOF_API_KEY=wp_your_api_key_here

# Server
TOOL_HOST_URL=https://your-server.example.com
PORT=3004
# NODE_ENV=production
