[Desktop Entry]
Type=Application
Name=CPOE
GenericName=Authorship Witnessing
Comment=Cryptographic authorship witnessing daemon - Kinetic Proof of Provenance
Exec=writerslogic %U
Icon=writerslogic
Terminal=false
Categories=Utility;Security;
Keywords=witness;authorship;cryptography;keystroke;biometrics;
StartupNotify=false
StartupWMClass=writerslogic
Actions=Status;Verify;

[Desktop Action Status]
Name=Show Status
Exec=writerslogic --status

[Desktop Action Verify]
Name=Verify Document
Exec=witnessctl verify %U
