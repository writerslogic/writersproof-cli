#!/usr/bin/make -f

# Debian rules file for cpoe

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export CARGO_TERM_COLOR = never

# Version information
VERSION := $(shell dpkg-parsechangelog -S Version | cut -d- -f1)
COMMIT := $(shell git rev-parse --short HEAD 2>/dev/null || echo "unknown")
BUILD_TIME := $(shell date -u +"%Y-%m-%dT%H:%M:%SZ")

%:
	dh $@

override_dh_auto_clean:
	cargo clean || true
	rm -rf bin/

override_dh_auto_build:
	# Build CLI binary
	cargo build --release --package cpoe_cli
	mkdir -p bin/
	cp target/release/cpoe bin/cpoe
	cp target/release/cpoe-native-messaging-host bin/ || true

override_dh_auto_test:
	cargo test --package cpoe_cli

override_dh_auto_install:
	# Install binaries
	install -D -m 755 bin/cpoe debian/cpoe/usr/bin/cpoe

	# Install man pages
	install -D -m 644 ../../docs/man/cpoe.1 debian/cpoe/usr/share/man/man1/cpoe.1

	# Install systemd units (if present)
	if [ -d packaging/linux/systemd ]; then \
		install -D -m 644 packaging/linux/systemd/cpoe.service debian/cpoe/lib/systemd/system/cpoe.service; \
		install -D -m 644 packaging/linux/systemd/cpoe-user.service debian/cpoe/usr/lib/systemd/user/cpoe.service; \
	fi

	# Install documentation
	install -D -m 644 ../../LICENSE debian/cpoe/usr/share/doc/cpoe/LICENSE
	install -D -m 644 README.md debian/cpoe/usr/share/doc/cpoe/README.md

override_dh_installsystemd:
	dh_installsystemd --name=cpoe
	dh_installsystemd --name=cpoe --user

override_dh_compress:
	dh_compress -X.md
