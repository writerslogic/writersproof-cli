#!/usr/bin/make -f

# Debian rules file for cpop

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export CARGO_TERM_COLOR = never

# Version information
VERSION := $(shell dpkg-parsechangelog -S Version | cut -d- -f1)
COMMIT := $(shell git rev-parse --short HEAD 2>/dev/null || echo "unknown")
BUILD_TIME := $(shell date -u +"%Y-%m-%dT%H:%M:%SZ")

%:
	dh $@

override_dh_auto_clean:
	cargo clean || true
	rm -rf bin/

override_dh_auto_build:
	# Build CLI binary
	cargo build --release --package cpop_cli
	mkdir -p bin/
	cp target/release/cpop bin/cpop
	cp target/release/cpop-native-messaging-host bin/ || true

override_dh_auto_test:
	cargo test --package cpop_cli

override_dh_auto_install:
	# Install binaries
	install -D -m 755 bin/cpop debian/cpop/usr/bin/cpop

	# Install man pages
	install -D -m 644 ../../docs/man/cpoe.1 debian/cpoe/usr/share/man/man1/cpoe.1

	# Install systemd units (if present)
	if [ -d packaging/linux/systemd ]; then \
		install -D -m 644 packaging/linux/systemd/cpop.service debian/cpop/lib/systemd/system/cpop.service; \
		install -D -m 644 packaging/linux/systemd/cpop-user.service debian/cpop/usr/lib/systemd/user/cpop.service; \
	fi

	# Install documentation
	install -D -m 644 ../../LICENSE debian/cpop/usr/share/doc/cpop/LICENSE
	install -D -m 644 README.md debian/cpop/usr/share/doc/cpop/README.md

override_dh_installsystemd:
	dh_installsystemd --name=cpop
	dh_installsystemd --name=cpop --user

override_dh_compress:
	dh_compress -X.md
