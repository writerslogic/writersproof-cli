#!/usr/bin/make -f

# Debian rules file for writersproof-cli

export DH_VERBOSE = 1
export CARGO_TERM_COLOR = never

%:
	dh $@ --buildsystem=none

override_dh_auto_clean:
	cargo clean || true
	rm -rf bin/

override_dh_auto_build:
	# Build the CLI binary (x11/wayland/dbus focus features are enabled
	# automatically on Linux via apps/cpoe_cli/Cargo.toml). Unset the
	# Debian-injected C flags: their -O2/-flto break aws-lc-sys's jitterentropy
	# (which requires -O0 and has an #error guard). Rust hardening comes from the
	# release profile, not CFLAGS.
	env -u CFLAGS -u CXXFLAGS -u CPPFLAGS -u LDFLAGS \
		cargo build --release --package cpoe_cli
	mkdir -p bin/
	cp target/release/writersproof-cli bin/writersproof-cli

override_dh_auto_install:
	# CLI binary
	install -D -m 755 bin/writersproof-cli debian/writersproof-cli/usr/bin/writersproof-cli

	# Man page
	install -D -m 644 docs/man/cpoe.1 debian/writersproof-cli/usr/share/man/man1/writersproof-cli.1

	# User systemd service only. The daemon must run inside the user's graphical
	# session (DISPLAY + /dev/input via the `input` group); a system service
	# cannot track focus, so none is shipped.
	if [ -f apps/cpoe_cli/packaging/linux/systemd/cpoe-user.service ]; then \
		install -D -m 644 apps/cpoe_cli/packaging/linux/systemd/cpoe-user.service \
			debian/writersproof-cli/usr/lib/systemd/user/writersproof-cli.service; \
	fi

	# Documentation
	install -D -m 644 LICENSE debian/writersproof-cli/usr/share/doc/writersproof-cli/LICENSE
	install -D -m 644 README.md debian/writersproof-cli/usr/share/doc/writersproof-cli/README.md

override_dh_compress:
	dh_compress -X.md
