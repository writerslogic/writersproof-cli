# SELinux Type Enforcement Policy for cpoe
#
# This policy module provides SELinux confinement for the cpoe daemon.
# It allows the daemon to perform its cryptographic authorship witnessing
# functions while maintaining security isolation.
#
# To compile and install:
#   checkmodule -M -m -o cpoe.mod cpoe.te
#   semodule_package -o cpoe.pp -m cpoe.mod
#   semodule -i cpoe.pp
#
# Or use the provided Makefile target:
#   make selinux

policy_module(cpoe, 1.0.0)

########################################
#
# Declarations
#

type cpoe_t;
type cpoe_exec_t;
init_daemon_domain(cpoe_t, cpoe_exec_t)

type cpoe_var_lib_t;
files_type(cpoe_var_lib_t)

type cpoe_var_log_t;
logging_log_file(cpoe_var_log_t)

type cpoe_etc_t;
files_config_file(cpoe_etc_t)

type cpoe_var_run_t;
files_pid_file(cpoe_var_run_t)

type cpoe_tmp_t;
files_tmp_file(cpoe_tmp_t)

########################################
#
# cpoe local policy
#

# Allow reading its own config
allow cpoe_t cpoe_etc_t:dir list_dir_perms;
allow cpoe_t cpoe_etc_t:file read_file_perms;

# Allow managing its own data
allow cpoe_t cpoe_var_lib_t:dir create_dir_perms;
allow cpoe_t cpoe_var_lib_t:file create_file_perms;
allow cpoe_t cpoe_var_lib_t:lnk_file { create read unlink };

# Allow logging
allow cpoe_t cpoe_var_log_t:dir create_dir_perms;
allow cpoe_t cpoe_var_log_t:file create_file_perms;
logging_log_filetrans(cpoe_t, cpoe_var_log_t, file)

# Allow runtime files (socket, pid)
allow cpoe_t cpoe_var_run_t:dir create_dir_perms;
allow cpoe_t cpoe_var_run_t:file create_file_perms;
allow cpoe_t cpoe_var_run_t:sock_file create_file_perms;
files_pid_filetrans(cpoe_t, cpoe_var_run_t, { file sock_file dir })

# Allow temporary files
allow cpoe_t cpoe_tmp_t:dir create_dir_perms;
allow cpoe_t cpoe_tmp_t:file create_file_perms;
files_tmp_filetrans(cpoe_t, cpoe_tmp_t, { file dir })

# Network access (for timestamping anchors)
allow cpoe_t self:tcp_socket create_stream_socket_perms;
allow cpoe_t self:udp_socket create_socket_perms;
corenet_tcp_connect_http_port(cpoe_t)
corenet_tcp_connect_https_port(cpoe_t)

# Allow reading passwd for user info
auth_use_nsswitch(cpoe_t)

# Allow signaling self
allow cpoe_t self:process { signal signull };

# Allow using its own unix sockets
allow cpoe_t self:unix_stream_socket create_stream_socket_perms;
allow cpoe_t self:unix_dgram_socket create_socket_perms;

# Misc
kernel_read_system_state(cpoe_t)
files_read_etc_files(cpoe_t)
miscfiles_read_localization(cpoe_t)

########################################
#
# File context definitions (to be used with cpoe.fc)
#

# See cpoe.fc for file context definitions
