# /etc/cpoe/environment
# Environment variables for cpoe daemon

# Log level: debug, info, warn, error
# CPOE_LOG_LEVEL=info

# Data directory for MMR database and witness logs
# CPOE_DATA_DIR=/var/lib/cpoe

# Configuration file path
# CPOE_CONFIG=/etc/cpoe/config.toml

# Socket path for IPC
# CPOE_SOCKET=/run/cpoe/cpoe.sock

# Enable verbose logging
# CPOE_VERBOSE=false

# Anchor configuration
# CPOE_ANCHOR_INTERVAL=3600

# Privacy settings
# CPOE_PRIVACY_MODE=strict

# Performance tuning
# CPOE_BUFFER_SIZE=4096
# CPOE_FLUSH_INTERVAL=60

# TLS settings (for remote anchoring)
# CPOE_TLS_CERT=/etc/cpoe/tls/cert.pem
# CPOE_TLS_KEY=/etc/cpoe/tls/key.pem

# Keybase integration
# CPOE_KEYBASE_USERNAME=
# CPOE_KEYBASE_ENABLE=false

# Blockchain anchoring
# CPOE_BLOCKCHAIN_ENABLE=false
# CPOE_BLOCKCHAIN_NETWORK=mainnet
