# Ironclad Configuration (use API key OR OAuth, not both)

# Option 1: API Key Authentication
IRONCLAD_API_KEY=your_api_key_here

# Option 2: OAuth Authentication
# IRONCLAD_CLIENT_ID=your_client_id
# IRONCLAD_CLIENT_SECRET=your_client_secret
# APP_BASE_URL=https://your-server.example.com

# Webhook Security
IRONCLAD_WEBHOOK_SECRET=your_webhook_secret_here

# WritersProof API
WRITERSPROOF_API_KEY=wp_your_api_key_here

# Server
PORT=3009
