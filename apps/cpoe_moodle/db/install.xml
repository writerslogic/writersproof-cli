<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/writersproof/db" VERSION="20260529" COMMENT="XMLDB file for local plugin writersproof"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_writersproof_sessions" COMMENT="WritersProof authorship attestation sessions">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="User who authored the content"/>
        <FIELD NAME="contextid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Moodle context ID"/>
        <FIELD NAME="cmid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Course module ID"/>
        <FIELD NAME="itemid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Content item ID (submission, post, page ID)"/>
        <FIELD NAME="itemtype" TYPE="char" LENGTH="50" NOTNULL="true" SEQUENCE="false" COMMENT="Content type: assignment_submission, forum_post, wiki_page, etc."/>
        <FIELD NAME="sessionid" TYPE="char" LENGTH="64" NOTNULL="false" SEQUENCE="false" COMMENT="WritersProof remote session ID"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="active" SEQUENCE="false" COMMENT="Session status: active, finalized, verified, failed"/>
        <FIELD NAME="contenthash" TYPE="char" LENGTH="64" NOTNULL="false" SEQUENCE="false" COMMENT="SHA-256 of latest content snapshot"/>
        <FIELD NAME="wordcount" TYPE="int" LENGTH="10" NOTNULL="false" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="evidencescore" TYPE="number" LENGTH="5" NOTNULL="false" DECIMALS="2" SEQUENCE="false" COMMENT="WritersProof evidence confidence score 0.00-1.00"/>
        <FIELD NAME="checkpointcount" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="fk_contextid" TYPE="foreign" FIELDS="contextid" REFTABLE="context" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_userid_itemtype_itemid" UNIQUE="false" FIELDS="userid, itemtype, itemid"/>
        <INDEX NAME="idx_cmid" UNIQUE="false" FIELDS="cmid"/>
        <INDEX NAME="idx_sessionid" UNIQUE="false" FIELDS="sessionid"/>
        <INDEX NAME="idx_status" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
