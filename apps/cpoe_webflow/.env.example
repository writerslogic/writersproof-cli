# Webflow Configuration
WEBFLOW_CLIENT_ID=your_client_id
WEBFLOW_CLIENT_SECRET=your_client_secret

# Pre-existing access token (optional, skips OAuth flow)
# WEBFLOW_ACCESS_TOKEN=your_access_token

# WritersProof API
WRITERSPROOF_API_KEY=wp_your_api_key_here

# Webhook Security
WEBHOOK_SECRET=generate_a_random_secret_here

# Server
PORT=3001
